# Contractor Directory - Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: API key for POST endpoints (generate a secure random string)
POST_API_KEY=your-secure-random-string
